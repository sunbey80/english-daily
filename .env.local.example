# 复制本文件为 .env.local，把下面占位值替换为真实值。
# .env.local 已在 .gitignore 中，不会被提交。

# ── Supabase ──────────────────────────────────────────────
# Settings → API Keys 页获取
NEXT_PUBLIC_SUPABASE_URL=https://kbtycoqitreovqjdidnr.supabase.co

# Publishable key（前端用，可公开）：Settings → API Keys → Publishable key → default
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret key（服务端用，高敏感，绝不进前端/git）：Settings → API Keys → Secret keys → New secret key
SUPABASE_SECRET_KEY=sb_secret_xxx

# ── LLM（OpenRouter，OpenAI 兼容）─────────────────────────
# 生成管线用，先 mock，接真模型时填
OPENROUTER_API_KEY=
# 可配置的模型名，例：anthropic/claude-opus-4-8 | openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-opus-4-8

# ── 内部接口保护 ──────────────────────────────────────────
# /api/generate 仅 Cron 调用，用此密钥保护（自行生成一段随机串）
GENERATE_SECRET=
